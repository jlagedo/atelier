# Thin wrapper over build.sh. See design.md §7 for the image spec.
.PHONY: all check rootfs initrd kernel bundle clean

all:    ; ./build.sh all
check:  ; ./build.sh check
rootfs: ; ./build.sh rootfs
initrd: ; ./build.sh initrd
kernel: ; ./build.sh kernel
bundle: ; ./build.sh bundle
clean:  ; ./build.sh clean
