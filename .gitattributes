# Normalize all text to LF in the repo and on checkout. The desktop app targets
# Windows but is developed on Linux/macOS — this prevents CRLF churn either way.
* text=auto eol=lf

# Explicit text types (defensive)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf

# Windows scripts must keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary assets (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
*.vhd   binary
*.vhdx  binary
*.exe   binary
